# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored; this example file is NOT.

# ── GraphQL backend ─────────────────────────────────────────────────────────
# The propeller backend's GraphQL endpoint. Server-side only (not exposed to
# the browser): all client GraphQL calls go through the /api/graphql proxy,
# which reads this and injects the API key + auth Bearer cookie upstream.
BOILERPLATE_GRAPHQL_ENDPOINT=https://api.example.com/v2/graphql

# Backend API key. Used by /api/graphql to authenticate the proxy itself
# (separate from the per-user auth Bearer). KEEP SECRET — server-side only.
BOILERPLATE_API_KEY=your_api_key_here

# Separate key used only for order-editor mutations, if your backend issues
# a distinct key for those. Same key as above is fine in dev.
BOILERPLATE_ORDER_EDITOR_API_KEY=your_order_editor_api_key_here

# ── Catalog defaults ────────────────────────────────────────────────────────
# Root category for menu navigation. The home page lists this category's
# direct children as the top-level menu.
BOILERPLATE_BASE_CATEGORY_ID=17

# Exposed to the browser so client-side links/components can build category
# URLs without a server round-trip. Keep in sync with the server var above.
NEXT_PUBLIC_BASE_CATEGORY_ID=17

# How deep to fetch the category tree for the menu (1 = top-level only).
BOILERPLATE_MENU_DEPTH=3

# ── Localization ────────────────────────────────────────────────────────────
# Default UI language. Two-letter ISO code, uppercased. Falls back to 'NL' if
# unset.
BOILERPLATE_DEFAULT_LANGUAGE=NL
NEXT_PUBLIC_DEFAULT_LANGUAGE=NL

# ── Portal mode ─────────────────────────────────────────────────────────────
# Catalog visibility mode — kebab-case values: 'open' | 'semi-closed' | 'closed'.
# 'semi-closed' hides prices / catalogue actions from anonymous visitors and
# omits the `offers` block from JSON-LD output. Falls back to 'open' if unset.
BOILERPLATE_PORTAL_MODE=open

# ── SEO / JSON-LD ───────────────────────────────────────────────────────────
# Absolute origin of this site (no trailing slash). Used to build absolute
# URLs in schema.org / JSON-LD payloads emitted by ProductJsonLd / ClusterJsonLd
# / ItemListJsonLd. When unset the JSON-LD emits path-only URLs (Google accepts
# these but absolute is preferred for canonicalisation).
NEXT_PUBLIC_SITE_URL=https://shop.example.com

# ── Unused / planned ────────────────────────────────────────────────────────
# Anonymous user identifier — declared but not currently referenced by any
# code. Reserved for future guest-checkout support. Leave unset or pick any
# integer; it has no effect today.
# BOILERPLATE_ANONYMOUS_USER_ID=0

# JWT_SECRET — historically intended for self-signing tokens but never
# wired up. JWTs are issued and verified upstream (Google Cloud Identity
# Platform). The /api/auth/session route does a decode-only shape check,
# no signing. SAFE TO LEAVE UNSET. If a future feature needs HMAC signing
# (e.g. session CSRF tokens), set a long random value here and document.
# JWT_SECRET=

# When true, the SDK sync script (npm run sdk:sync) installs from the local
# d:/laragon/www/npm/propeller-sdk-v2 workspace via --install-links instead
# of fetching the GitHub master branch declared in package.json. Dev only.
SDK_LOCAL=true
