# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored; this example file is NOT.

# ── GraphQL backend ─────────────────────────────────────────────────────────
# The propeller backend's GraphQL endpoint. Server-side only (not exposed to
# the browser): all client GraphQL calls go through the /api/graphql proxy,
# which reads this and injects the API key + auth Bearer cookie upstream.
BOILERPLATE_GRAPHQL_ENDPOINT=https://api.example.com/v2/graphql

# Backend API key. Used by /api/graphql to authenticate the proxy itself
# (separate from the per-user auth Bearer). KEEP SECRET — server-side only.
BOILERPLATE_API_KEY=your_api_key_here

# Separate key used only for order-editor mutations, if your backend issues
# a distinct key for those. Same key as above is fine in dev.
BOILERPLATE_ORDER_EDITOR_API_KEY=your_order_editor_api_key_here

# ── Catalog defaults ────────────────────────────────────────────────────────
# Root category for menu navigation. The home page lists this category's
# direct children as the top-level menu.
BOILERPLATE_BASE_CATEGORY_ID=17

# Exposed to the browser so client-side links/components can build category
# URLs without a server round-trip. Keep in sync with the server var above.
NEXT_PUBLIC_BASE_CATEGORY_ID=17

# How deep to fetch the category tree for the menu (1 = top-level only).
BOILERPLATE_MENU_DEPTH=3

# ── Localization ────────────────────────────────────────────────────────────
# Default UI language. Two-letter ISO code, uppercased. Falls back to 'NL' if
# unset.
BOILERPLATE_DEFAULT_LANGUAGE=NL
NEXT_PUBLIC_DEFAULT_LANGUAGE=NL

# ── Portal mode ─────────────────────────────────────────────────────────────
# Catalog visibility mode — kebab-case values: 'open' | 'semi-closed' | 'closed'.
# 'semi-closed' hides prices / catalogue actions from anonymous visitors and
# omits the `offers` block from JSON-LD output. Falls back to 'open' if unset.
BOILERPLATE_PORTAL_MODE=open

# ── CMS ─────────────────────────────────────────────────────────────────────
# Which CMS backend powers marketing content (rich pages at /{slug}, the blog,
# the homepage blocks, header/footer globals, category banners). The provider
# is selected at runtime by lib/cms/index.ts; all providers ship in the
# boilerplate, so switching is just a matter of this var + the matching
# credentials below. 'none' (the default) makes marketing slugs 404 and the
# homepage fall back to its built-in static structure.
#   none       — no CMS (default)
#   strapi     — self-hosted Strapi (set STRAPI_API_URL [+ STRAPI_API_TOKEN])
#   prepr      — hosted Prepr GraphQL CMS (set PREPR_ACCESS_TOKEN)
#   contentful — hosted Contentful GraphQL CMS (set CONTENTFUL_SPACE_ID +
#                CONTENTFUL_CDA_TOKEN). SaaS-only; runs against a cloud Space.
CMS_PROVIDER=none
# NEXT_PUBLIC_CMS_PROVIDER mirrors the above for any client-side branch; keep
# the two in sync.
# NEXT_PUBLIC_CMS_PROVIDER=none

# Strapi (only used when CMS_PROVIDER=strapi)
# STRAPI_API_URL=http://localhost:1337
# NEXT_PUBLIC_STRAPI_API_URL=http://localhost:1337
# STRAPI_API_TOKEN=

# Prepr (only used when CMS_PROVIDER=prepr) — Prepr authenticates by putting
# the access token in the GraphQL URL, so there is no separate CMS URL.
# PREPR_ACCESS_TOKEN=your-prepr-graphql-token

# Contentful (only used when CMS_PROVIDER=contentful). SaaS-only — there is no
# self-hosted Contentful; the app reads from a cloud Space over GraphQL.
# CONTENTFUL_SPACE_ID=
# CONTENTFUL_ENVIRONMENT=master
# CONTENTFUL_CDA_TOKEN=        # Content Delivery API token (published content)
# Optional — fetch unpublished drafts via the Content Preview API:
# CONTENTFUL_CPA_TOKEN=        # Content Preview API token
# CONTENTFUL_PREVIEW=false     # set true to read drafts via the CPA token

# ── Payments (Mollie PSP) ───────────────────────────────────────────────────
# Active payment provider. 'mollie' turns on the Mollie checkout flow (the
# checkout redirects to Mollie's hosted page after placing the order, and the
# /api/mollie/webhook route reconciles order/payment state). Leave unset/empty
# for the default behaviour (place order → straight to thank-you, no PSP).
# PAYMENT_PROVIDER=mollie
# Client-side mirror — the checkout page reads this to decide whether to start a
# Mollie payment. Keep in sync with PAYMENT_PROVIDER.
# NEXT_PUBLIC_PAYMENT_PROVIDER=mollie

# Mollie API keys (only used when PAYMENT_PROVIDER=mollie). KEEP SECRET —
# server-side only. Get these from the Mollie Dashboard (Developers → API keys).
# MOLLIE_LIVE_KEY=live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MOLLIE_TEST_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# When true the test key is used; false uses the live key. Defaults to true.
# MOLLIE_TEST_MODE=true

# ISO 4217 currency CODE sent to Mollie (e.g. EUR/USD/GBP). This is the 3-letter
# code, NOT the display symbol used elsewhere in the UI. Defaults to EUR.
# NEXT_PUBLIC_CURRENCY_CODE=EUR

# Payment methods that settle ON ACCOUNT and do NOT go through a PSP. Comma-
# separated, case-insensitive. For these the order is placed straight to NEW and
# Mollie is skipped; every other method goes through Mollie (order starts as
# UNFINISHED until the webhook sets the final status). Defaults to
# "REKENING,ON_ACCOUNT" when unset.
# ON_ACCOUNT_PAYMENTS=REKENING,ON_ACCOUNT
# Client mirror — the checkout page reads this to decide the order status and
# whether to start a Mollie payment. Keep in sync with ON_ACCOUNT_PAYMENTS.
# NEXT_PUBLIC_ON_ACCOUNT_PAYMENTS=REKENING,ON_ACCOUNT

# Mollie POSTs its webhook to NEXT_PUBLIC_SITE_URL + /api/mollie/webhook, which
# must be PUBLICLY reachable over HTTPS. Mollie cannot reach localhost or LAN IPs
# — in dev, expose your server with a tunnel (ngrok / cloudflared) and either set
# NEXT_PUBLIC_SITE_URL to the tunnel URL, or use MOLLIE_WEBHOOK_URL below to point
# ONLY the webhook at the tunnel while keeping the shopper-facing redirect on your
# normal local URL.
#
# Optional override for the webhook URL Mollie is told to call. Set this to a
# public tunnel when NEXT_PUBLIC_SITE_URL points at a non-public address. Accepts
# either a bare origin (we append /api/mollie/webhook) or the full webhook URL.
# MOLLIE_WEBHOOK_URL=https://your-tunnel.ngrok-free.app

# ── Payments (MultiSafepay PSP) ─────────────────────────────────────────────
# MultiSafepay is an ALTERNATIVE PSP to Mollie — set PAYMENT_PROVIDER=multisafepay
# (instead of 'mollie') to route checkout through MultiSafepay's hosted page. Only
# one PSP is active at a time. The /api/msp/webhook route reconciles order/payment
# state. Leave PAYMENT_PROVIDER unset/empty for no PSP (place order → thank-you).
# PAYMENT_PROVIDER=multisafepay
# NEXT_PUBLIC_PAYMENT_PROVIDER=multisafepay

# MultiSafepay API keys (only used when PAYMENT_PROVIDER=multisafepay). KEEP
# SECRET — server-side only. Get these from the MultiSafepay Dashboard
# (Settings → Website Settings → API key). MultiSafepay has SEPARATE live/test
# accounts+hosts: the test key works against testapi.multisafepay.com, the live
# key against api.multisafepay.com. MSP_TEST_MODE selects which.
# MSP_LIVE_KEY=your_live_site_api_key
# MSP_TEST_KEY=your_test_site_api_key
# When true (default) the test key + test host are used; false uses live.
# MSP_TEST_MODE=true

# MultiSafepay POSTs its notification to NEXT_PUBLIC_SITE_URL + /api/msp/webhook
# with ?transactionid=<orderId>, which must be PUBLICLY reachable over HTTPS
# (MultiSafepay cannot reach localhost — use a tunnel like cloudflared/ngrok in
# dev). Optional override so ONLY the webhook targets the tunnel while the
# shopper redirect stays on NEXT_PUBLIC_SITE_URL. Bare origin (we append
# /api/msp/webhook) or the full webhook URL.
# MSP_WEBHOOK_URL=https://your-tunnel.trycloudflare.com

# NOTE: MultiSafepay reuses the shared payment vars below (also used by Mollie):
#   ON_ACCOUNT_PAYMENTS / NEXT_PUBLIC_ON_ACCOUNT_PAYMENTS — methods that skip the
#     PSP and place straight to NEW.
#   NEXT_PUBLIC_CURRENCY_CODE — the ISO 4217 currency sent to the PSP.

# ── SEO / JSON-LD ───────────────────────────────────────────────────────────
# Absolute origin of this site (no trailing slash). Used to build absolute
# URLs in schema.org / JSON-LD payloads emitted by ProductJsonLd / ClusterJsonLd
# / ItemListJsonLd. When unset the JSON-LD emits path-only URLs (Google accepts
# these but absolute is preferred for canonicalisation).
NEXT_PUBLIC_SITE_URL=https://shop.example.com

# ── Unused / planned ────────────────────────────────────────────────────────
# Anonymous user identifier — declared but not currently referenced by any
# code. Reserved for future guest-checkout support. Leave unset or pick any
# integer; it has no effect today.
# BOILERPLATE_ANONYMOUS_USER_ID=0

# JWT_SECRET — historically intended for self-signing tokens but never
# wired up. JWTs are issued and verified upstream (Google Cloud Identity
# Platform). The /api/auth/session route does a decode-only shape check,
# no signing. SAFE TO LEAVE UNSET. If a future feature needs HMAC signing
# (e.g. session CSRF tokens), set a long random value here and document.
# JWT_SECRET=
