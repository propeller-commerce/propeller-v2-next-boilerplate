      "type": "string",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string"
    },
    "subtitle": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "ctaText": {
      "type": "string"
    },
    "ctaUrl": {
      "type": "string"
    }
  }
}
