{
  "kind": "collectionType",
  "collectionName": "category_banners",
  "info": {
    "singularName": "category-banner",
    "pluralName": "category-banners",
    "displayName": "Category Banner",
    "description": "Banner images linked to Propeller category IDs"
  },
