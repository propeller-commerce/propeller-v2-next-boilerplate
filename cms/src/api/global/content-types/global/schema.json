{
  "kind": "singleType",
  "collectionName": "globals",
  "info": {
    "singularName": "global",
    "pluralName": "globals",
    "displayName": "Global",
    "description": "Define global settings for header, footer and SEO"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteName": {
      "type": "string",
      "required": true
    },
    "siteDescription": {
      "type": "text",
      "required": true
    },
    "favicon": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "defaultSeo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "logoAlt": {
      "type": "string",
      "default": "Logo"
    },
    "topBarEnabled": {
      "type": "boolean",
      "default": true
    },
    "topBarPhone": {
      "type": "string"
    },
    "topBarAnnouncement": {
      "type": "string"
    },
    "topBarAnnouncementEnabled": {
      "type": "boolean",
      "default": false
    },
    "showVatToggle": {
      "type": "boolean",
      "default": true
    },
    "showLanguageSwitcher": {
      "type": "boolean",
      "default": true
    },
    "availableLanguages": {
      "type": "string",
      "default": "EN,NL"
    },
    "showSearch": {
      "type": "boolean",
      "default": true
    },
    "showAccount": {
      "type": "boolean",
      "default": true
    },
    "showCart": {
      "type": "boolean",
      "default": true
    },
    "showCategoriesMenu": {
      "type": "boolean",
      "default": true
    },
    "categoriesMenuLabel": {
      "type": "string",
      "default": "Browse Categories"
    },
    "navLinks": {
      "type": "component",
      "repeatable": true,
      "component": "shared.nav-link"
    },
    "footerDescription": {
      "type": "text"
    },
    "footerColumns": {
      "type": "component",
      "repeatable": true,
      "component": "shared.footer-column"
    },
    "footerEmail": {
      "type": "string"
    },
    "footerPhone": {
      "type": "string"
    },
    "copyrightText": {
      "type": "string"
    }
  }
}
