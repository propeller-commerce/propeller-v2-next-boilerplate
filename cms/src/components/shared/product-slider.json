{
  "collectionName": "components_shared_product_sliders",
  "info": {
    "displayName": "Product Slider",
    "icon": "shoppingCart",
    "description": "Displays products/clusters from Propeller by ID"
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "productIds": {
      "type": "string",
      "pluginOptions": {},
      "regex": "^[0-9,\\s]*$"
    },
    "clusterIds": {
      "type": "string",
      "pluginOptions": {},
      "regex": "^[0-9,\\s]*$"
    }
  }
}
