        </mxCell>
        <mxCell id="e-ssr-cat-strapi" edge="1" parent="1" source="ssr-catbanner" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;dashed=1;" target="strapi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e-admin-mysql" edge="1" parent="1" source="admin-api" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;fontSize=10;labelBackgroundColor=#ffffff;" target="mysql" value="validate + CRUD">
