        <mxCell id="e-ssr-home-strapi" edge="1" parent="1" source="ssr-home" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;dashed=1;" target="strapi">
