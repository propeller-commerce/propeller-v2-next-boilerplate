{
  "name": "propeller-next",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "locales:build": "node scripts/build-locales-registry.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/build-locales-registry.mjs",
    "predev": "node scripts/build-locales-registry.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force .next -ErrorAction SilentlyContinue; Remove-Item -Recurse -Force out -ErrorAction SilentlyContinue\"",
    "sdk:sync": "npm update @propeller-commerce/propeller-sdk-v2 && npm install --install-links",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@contentful/rich-text-html-renderer": "^17.2.2",
    "@contentful/rich-text-types": "^17.2.7",
    "@propeller-commerce/propeller-sdk-v2": "^0.12.0",
    "@propeller-commerce/propeller-v2-mollie": "^0.2.3",
    "@propeller-commerce/propeller-v2-msp": "^0.1.1",
    "@propeller-commerce/propeller-v2-react-ui": "^0.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.560.0",
    "marked": "^17.0.5",
    "next": "16.0.10",
    "qs": "^6.15.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.6.0",
    "swiper": "^12.0.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20",
    "@types/qs": "^6.14.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "baseline-browser-mapping": "^2.10.18",
    "eslint": "^9",
    "eslint-config-next": "16.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
